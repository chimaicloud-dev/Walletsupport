# ============================================================
# Wallet Support ExPJdev — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Database -----------------------------------------------
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Authentication -----------------------------------------
# Secret key used to sign JWT tokens — use a long random string in production
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here

# ---- Server (optional) --------------------------------------
# Port for local development (defaults vary per service)
# PORT=3000
