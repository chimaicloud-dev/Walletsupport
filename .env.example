# ============================================================
# Wallet Support ExPJdev — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Database -----------------------------------------------
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Clerk Authentication -----------------------------------
# From https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ---- Frontend (Vite — prefix with VITE_) --------------------
# Same publishable key as above, exposed to the browser
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Clerk Frontend API proxy URL — use your own domain + /api/__clerk
# e.g. https://your-app.vercel.app/api/__clerk
VITE_CLERK_PROXY_URL=https://your-app.vercel.app/api/__clerk

# ---- Server (optional) --------------------------------------
# Port for local development (defaults to 3000 for API, 5173 for frontend)
# PORT=3000
